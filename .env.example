# Required for Cloudflare Radar tile. Free token at https://dash.cloudflare.com/profile/api-tokens (Radar - Read template).
CF_RADAR_TOKEN=

# Optional. Get a free key at https://console.cloud.google.com/apis/credentials (enable YouTube Data API v3).
YT_API_KEY=

# Optional. Higher rate limits for Stack Overflow. Register at https://stackapps.com/
SO_API_KEY=
